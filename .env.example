# ─── Telegram ────────────────────────────────────────────────────────────────
# Never expose these to Layer 1 modules.
TELEGRAM_BOT_TOKEN="123456789:YOUR_BOT_TOKEN_HERE"
TELEGRAM_WEBHOOK_SECRET="your_secure_random_string"

# ─── GitHub App ──────────────────────────────────────────────────────────────
# Never expose these to Layer 1 modules.
# Private key: paste the full PEM contents on a single line, \n for newlines.
GITHUB_APP_ID="123456"
GITHUB_WEBHOOK_SECRET="your_github_webhook_secret"
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# ─── Runtime ─────────────────────────────────────────────────────────────────
ENVIRONMENT="development"          # development | production
LOG_LEVEL="debug"                  # debug | info | warn | error
DENO_KV_PATH="./local_stos.db"    # local dev only — ignored on Deno Deploy

# ─── Deno Deploy (production) ────────────────────────────────────────────────
# Set these in the Deno Deploy project dashboard — not in this file.
# Deno Deploy does not read .env files.
#
# Required production values:
#   ENVIRONMENT=production
#   LOG_LEVEL=info
#   (DENO_KV_PATH is not used — Deno Deploy manages KV automatically)
