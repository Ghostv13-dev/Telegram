{
  "name": "stos-v2",
  "version": "2.3.2",

  "tasks": {
    "dev":      "deno run --allow-net --allow-env --allow-read --allow-write=./local_stos.db main.ts",
    "start":    "deno run --allow-net --allow-env --allow-read main.ts",
    "test":     "deno test --allow-read --allow-env --allow-net --allow-write=./local_stos.db",
    "coverage": "deno test --coverage=coverage/ && deno coverage coverage/",
    "check":    "deno check main.ts"
  },

  "fmt": {
    "indentWidth": 2,
    "singleQuote": false,
    "lineWidth": 100
  },

  "lint": {
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-explicit-any"]
    }
  },

  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },

  "imports": {
    "@std/assert":  "jsr:@std/assert@^1.0.0",
    "@std/crypto":  "jsr:@std/crypto@^1.0.0",
    "@std/encoding":"jsr:@std/encoding@^1.0.0"
  }
}
